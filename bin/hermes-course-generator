#!/usr/bin/env python3
import os
import sys
import shutil
import argparse
import re
import subprocess
from datetime import datetime
import json

try:
    import frontmatter as fm_lib
    _HAS_FRONTMATTER = True
except ImportError:
    _HAS_FRONTMATTER = False

try:
    import jsonschema
    _HAS_JSONSCHEMA = True
except ImportError:
    _HAS_JSONSCHEMA = False

TEMPLATE_DIR = os.path.expanduser("~/.config/hermes-course-generator/templates")

STATE_SCHEMA = {
    "type": "object",
    "properties": {
        "workspace_version": {"type": "string"},
        "technology": {"type": "string"},
        "technology_version": {"type": "string"},
        "course_name": {"type": "string"},
        "course_language": {"type": "string"},
        "created_at": {"type": "string"},
        "last_updated_at": {"type": "string"},
        "active_level": {"type": "string"},
        "active_lesson_id": {"type": "string"},
        "active_section_id": {"type": "string"},
        "locked_section": {"type": "string"}
    },
    "required": [
        "workspace_version", "technology", "technology_version", "course_name",
        "course_language", "created_at", "last_updated_at", "active_level",
        "active_lesson_id", "active_section_id", "locked_section"
    ],
    "additionalProperties": True
}


def main():
    parser = argparse.ArgumentParser(description="Hermes Course Generator CLI")
    subparsers = parser.add_subparsers(dest="command", required=True)
    
    # init
    init_parser = subparsers.add_parser("init", help="Initialize a new course workspace")
    init_parser.add_argument("--path", default=os.getcwd(), help="Workspace path")
    
    # merge
    merge_parser = subparsers.add_parser("merge", help="Merge sections into a lesson")
    merge_parser.add_argument("--level", required=True, choices=["begin", "advance", "master"], help="Level of the lesson")
    merge_parser.add_argument("--lesson", required=True, help="Lesson ID (e.g. L01)")
    merge_parser.add_argument("--path", default=os.getcwd(), help="Workspace path")
    
    # state
    state_parser = subparsers.add_parser("state", help="Manage state.json")
    state_subparsers = state_parser.add_subparsers(dest="state_command", required=True)
    
    state_update = state_subparsers.add_parser("update", help="Update state.json")
    state_update.add_argument("--path", default=os.getcwd(), help="Workspace path")
    state_update.add_argument("--key", required=True, help="State key to update")
    state_update.add_argument("--value", required=True, help="State value")

    state_clear_lock = state_subparsers.add_parser("clear-lock", help="Clear locked section in state.json")
    state_clear_lock.add_argument("--path", default=os.getcwd(), help="Workspace path")

    # clear-lock (top-level shortcut)
    clear_lock_parser = subparsers.add_parser("clear-lock", help="Clear locked section in state.json")
    clear_lock_parser.add_argument("--path", default=os.getcwd(), help="Workspace path")

    # verify
    verify_parser = subparsers.add_parser("verify", help="Verify all section files for format, metadata, and headings")
    verify_parser.add_argument("--path", default=os.getcwd(), help="Workspace path")
    verify_parser.add_argument("--level", choices=["begin", "advance", "master", "all"], default="all", help="Level to verify")
    verify_parser.add_argument("--build", action="store_true", help="Run a real Docusaurus build compiler check")

    # reorder
    reorder_parser = subparsers.add_parser("reorder", help="Scan and reorder sidebar positions in section files")
    reorder_parser.add_argument("--path", default=os.getcwd(), help="Workspace path")
    reorder_parser.add_argument("--level", choices=["begin", "advance", "master", "all"], default="all", help="Level to reorder")
    reorder_parser.add_argument("--mode", choices=["flat", "nested"], default="flat", help="Reorder mode: flat (sequential 1..N) or nested (1..6 per lesson)")
    
    # status
    status_parser = subparsers.add_parser("status", help="Scan workspace status and progress")
    status_parser.add_argument("--path", default=os.getcwd(), help="Workspace path")
    status_parser.add_argument("--level", choices=["begin", "advance", "master", "all"], default=None, help="Level to check status")
    status_parser.add_argument("--json", action="store_true", help="Output status as structured JSON")

    # evaluate
    evaluate_parser = subparsers.add_parser("evaluate", help="Evaluate a single section file and output JSON report")
    evaluate_parser.add_argument("--level", required=True, choices=["begin", "advance", "master"], help="Level of the section")
    evaluate_parser.add_argument("--file", required=True, help="Filename of the section (e.g. L01_S01_intro.mdx)")
    evaluate_parser.add_argument("--path", default=os.getcwd(), help="Workspace path")

    args = parser.parse_args()
    
    if args.command == "init":
        init_workspace(args.path)
    elif args.command == "merge":
        merge_lesson(args.path, args.level, args.lesson)
    elif args.command == "state":
        if args.state_command == "update":
            update_state(args.path, args.key, args.value)
        elif args.state_command == "clear-lock":
            clear_locked_section(args.path)
    elif args.command == "clear-lock":
        clear_locked_section(args.path)
    elif args.command == "verify":
        success = cmd_verify(args.path, args.level, args.build)
        sys.exit(0 if success else 1)
    elif args.command == "reorder":
        cmd_reorder(args.path, args.level, args.mode)
    elif args.command == "status":
        cmd_status(args.path, args.level, args.json)
    elif args.command == "evaluate":
        success = cmd_evaluate(args.path, args.level, args.file)
        sys.exit(0 if success else 1)

# -- utility functions --
def migrate_state_if_needed(target_path):
    state_path_md = os.path.join(target_path, "state.md")
    state_path_json = os.path.join(target_path, "state.json")
    if os.path.exists(state_path_md) and not os.path.exists(state_path_json):
        print(f"Migrating state.md to state.json in {target_path}...")
        try:
            with open(state_path_md, "r", encoding="utf-8") as f:
                content = f.read()
            
            keys = [
                "workspace_version", "technology", "technology_version", "course_name",
                "course_language", "created_at", "last_updated_at", "active_level",
                "active_lesson_id", "active_section_id", "locked_section"
            ]
            state_data = {}
            for k in keys:
                match = re.search(rf'^{k}:\s*["\']?(.*?)["\']?\s*$', content, re.MULTILINE)
                state_data[k] = match.group(1) if match else ""
            
            if not state_data.get("workspace_version"):
                state_data["workspace_version"] = "1.0"
            if not state_data.get("course_language"):
                state_data["course_language"] = "en"
            now_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            if not state_data.get("created_at"):
                state_data["created_at"] = now_str
            if not state_data.get("last_updated_at"):
                state_data["last_updated_at"] = now_str
                
            with open(state_path_json, "w", encoding="utf-8") as f:
                json.dump(state_data, f, indent=2)
            
            bak_path = state_path_md + ".bak"
            if os.path.exists(bak_path):
                os.remove(bak_path)
            os.rename(state_path_md, bak_path)
            print(f"Migration completed. Backed up state.md to state.md.bak")
        except Exception as e:
            print(f"Error during state migration: {e}", file=sys.stderr)

def read_state(target_path, key):
    migrate_state_if_needed(target_path)
    state_path_json = os.path.join(target_path, "state.json")
    if os.path.exists(state_path_json):
        try:
            with open(state_path_json, "r", encoding="utf-8") as f:
                data = json.load(f)
            return data.get(key)
        except Exception:
            pass
            
    state_path_md = os.path.join(target_path, "state.md")
    if os.path.exists(state_path_md):
        try:
            with open(state_path_md, "r", encoding="utf-8") as f:
                content = f.read()
            match = re.search(rf'^{key}:\s*["\']?(.*?)["\']?\s*$', content, re.MULTILINE)
            return match.group(1) if match else None
        except Exception:
            pass
            
    # Try reading from bak as absolute fallback
    state_path_bak = os.path.join(target_path, "state.md.bak")
    if os.path.exists(state_path_bak):
        try:
            with open(state_path_bak, "r", encoding="utf-8") as f:
                content = f.read()
            match = re.search(rf'^{key}:\s*["\']?(.*?)["\']?\s*$', content, re.MULTILINE)
            return match.group(1) if match else None
        except Exception:
            pass
    return None

def remove_vietnamese_diacritics(text):
    diacritics_map = {
        'a': 'áàảãạăắằẳẵặâấầẩẫậ', 'd': 'đ', 'e': 'éèẻẽẹêếềểễệ', 'i': 'íìỉĩị',
        'o': 'óòỏõọôốồổỗộơớờởỡợ', 'u': 'úùủũụưứừửữự', 'y': 'ýỳỷỹỵ',
        'A': 'ÁÀẢÃẠĂẮẰẲẴẶÂẤẦẨẪẬ', 'D': 'Đ', 'E': 'ÉÈẺẼẸÊẾỀỂễỆ', 'I': 'ÍÌỈĨỊ',
        'O': 'ÓÒỎÕỌÔỐỒỔỖỘƠỚỜỞỠỢ', 'U': 'ÚÙỦŨỤƯỨỪỬỮỰ', 'Y': 'ÝỲỶỸỴ'
    }
    for non_diacritic, diacritics in diacritics_map.items():
        for char in diacritics:
            text = text.replace(char, non_diacritic)
    return text

def slugify(text):
    text = remove_vietnamese_diacritics(text)
    text = text.lower()
    text = re.sub(r'[^a-z0-9\s\-]', '', text)
    text = re.sub(r'[\s_]+', '-', text)
    text = re.sub(r'-+', '-', text)
    text = text.strip('-')
    return text

def parse_frontmatter(content):
    if _HAS_FRONTMATTER:
        try:
            post = fm_lib.loads(content)
            return dict(post.metadata), post.content
        except Exception:
            pass
    if not content.startswith("---"):
        return {}, content
    parts = content.split("---", 2)
    if len(parts) < 3:
        return {}, content
    yaml_text = parts[1]
    body_text = parts[2]
    
    metadata = {}
    lines = yaml_text.strip().split("\n")
    current_key = None
    
    for line in lines:
        line = line.strip()
        if not line:
            continue
        if line.startswith("-") and current_key:
            val = line[1:].strip().strip('"\'')
            if not isinstance(metadata[current_key], list):
                metadata[current_key] = []
            metadata[current_key].append(val)
        elif ":" in line:
            key, val = line.split(":", 1)
            key = key.strip()
            val = val.strip().strip('"\'')
            if val == "":
                metadata[key] = []
                current_key = key
            else:
                metadata[key] = val
                current_key = None
    return metadata, body_text

def demote_headings(markdown_text):
    in_code_block = False
    new_lines = []
    lines = markdown_text.split("\n")
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("```"):
            in_code_block = not in_code_block
            new_lines.append(line)
            continue
        if not in_code_block:
            match = re.match(r'^(#+)\s+(.*)$', line)
            if match:
                hashes = match.group(1)
                content = match.group(2)
                new_lines.append(f"#{hashes} {content}")
            else:
                new_lines.append(line)
        else:
            new_lines.append(line)
    return "\n".join(new_lines)

# -- commands --
def init_workspace(target_path):
    target_path = os.path.abspath(target_path)
    print(f"Initializing course workspace at: {target_path}")
    
    if not os.path.exists(TEMPLATE_DIR):
        print(f"Error: Global templates not found at {TEMPLATE_DIR}", file=sys.stderr)
        sys.exit(1)
        
    os.makedirs(target_path, exist_ok=True)
    
    print("Copying instruction files and templates...")
    for filename in os.listdir(TEMPLATE_DIR):
        src_file = os.path.join(TEMPLATE_DIR, filename)
        dest_file = os.path.join(target_path, filename)
        if os.path.isfile(src_file):
            shutil.copy2(src_file, dest_file)
            
    print("Creating output directory structure...")
    subdirs = [
        "output/sections/begin", "output/sections/advance", "output/sections/master",
        "output/lessons/begin", "output/lessons/advance", "output/lessons/master",
        "output/reviews/sections/begin", "output/reviews/sections/advance", "output/reviews/sections/master",
        "output/reviews/lessons/begin", "output/reviews/lessons/advance", "output/reviews/lessons/master",
    ]
    for subdir in subdirs:
        os.makedirs(os.path.join(target_path, subdir), exist_ok=True)
        
    state_path_json = os.path.join(target_path, "state.json")
    if not os.path.exists(state_path_json):
        now_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        default_state = {
            "workspace_version": "1.0",
            "technology": "",
            "technology_version": "",
            "course_name": "",
            "course_language": "en",
            "created_at": now_str,
            "last_updated_at": now_str,
            "active_level": "",
            "active_lesson_id": "",
            "active_section_id": "",
            "locked_section": ""
        }
        with open(state_path_json, "w", encoding="utf-8") as f:
            json.dump(default_state, f, indent=2)
            
    changelog_path = os.path.join(target_path, "output/changelog.md")
    if not os.path.exists(changelog_path):
        with open(changelog_path, "w", encoding="utf-8") as f:
            f.write("# Changelog\n\nAll notable changes to this course will be documented in this file.\n")
            
    print("\nWorkspace initialized successfully!")

def update_state(target_path, key, value):
    target_path = os.path.abspath(target_path)
    migrate_state_if_needed(target_path)
    
    state_path_json = os.path.join(target_path, "state.json")
    state_data = {}
    if os.path.exists(state_path_json):
        try:
            with open(state_path_json, "r", encoding="utf-8") as f:
                state_data = json.load(f)
        except Exception as e:
            print(f"Warning: Failed to load existing state.json: {e}", file=sys.stderr)
            
    if not state_data:
        now_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        state_data = {
            "workspace_version": "1.0",
            "technology": "",
            "technology_version": "",
            "course_name": "",
            "course_language": "en",
            "created_at": now_str,
            "last_updated_at": now_str,
            "active_level": "",
            "active_lesson_id": "",
            "active_section_id": "",
            "locked_section": ""
        }
        
    state_data[key] = value
    state_data["last_updated_at"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    if _HAS_JSONSCHEMA:
        try:
            jsonschema.validate(instance=state_data, schema=STATE_SCHEMA)
        except jsonschema.exceptions.ValidationError as ve:
            print(f"Validation error: State update failed validation against schema: {ve.message}", file=sys.stderr)
            raise ValueError(f"State validation failed: {ve.message}")
    else:
        required_keys = STATE_SCHEMA["required"]
        for rk in required_keys:
            if rk not in state_data:
                raise ValueError(f"State validation failed: Missing required key '{rk}'")
            if not isinstance(state_data[rk], str):
                raise ValueError(f"State validation failed: Key '{rk}' must be a string, got {type(state_data[rk])}")
                
    with open(state_path_json, "w", encoding="utf-8") as f:
        json.dump(state_data, f, indent=2)
    print(f"Updated {key} to {value} in state.json")

def clear_locked_section(target_path):
    update_state(target_path, "locked_section", "")

def merge_lesson(target_path, level, lesson_id):
    target_path = os.path.abspath(target_path)
    sections_dir = os.path.join(target_path, f"output/sections/{level}")
    
    if not os.path.exists(sections_dir):
        print(f"Error: Directory {sections_dir} does not exist.")
        sys.exit(1)
        
    # Find all section files for the lesson (MDX files)
    section_files = [f for f in os.listdir(sections_dir) if f.startswith(f"{lesson_id}_S") and f.endswith(".mdx")]
    if not section_files:
        print(f"Error: No .mdx section files found for lesson {lesson_id} in {sections_dir}")
        sys.exit(1)
        
    # Sort files by section ID
    section_files.sort()
    
    sections_data = []
    lesson_title = ""
    language_version = ""
    
    print(f"Found {len(section_files)} sections for {lesson_id}. Analyzing...")
    
    for f in section_files:
        file_path = os.path.join(sections_dir, f)
        with open(file_path, "r", encoding="utf-8") as file:
            content = file.read()
            
        meta, body = parse_frontmatter(content)
        sec_id = meta.get("section_id", "")
        sec_title = meta.get("section_title", "")
        status = meta.get("status", "draft")
        score = float(meta.get("review_score", "0"))
        
        if not lesson_title:
            lesson_title = meta.get("lesson_title", "Unknown Lesson")
        if not language_version:
            language_version = meta.get("language_version", "")
            
        print(f"  - {f}: status={status}, score={score}")
        if status != "approved" or score < 8.0:
            print(f"    WARNING: Section {sec_id} is not approved or score < 8.0!")
            
        sections_data.append({
            "id": sec_id,
            "title": sec_title,
            "file": f,
            "body": body
        })
        
    lesson_slug = slugify(lesson_title)
    lesson_id_lower = lesson_id.lower()
    current_date = datetime.now().strftime("%Y-%m-%d")
    course_language = read_state(target_path, "course_language") or "en"
    
    # Build YAML frontmatter for lesson
    try:
        sidebar_pos_match = re.search(r'\d+', lesson_id)
        sidebar_pos = int(sidebar_pos_match.group()) if sidebar_pos_match else 1
    except Exception:
        sidebar_pos = 1

    yaml_lines = [
        "---",
        f"id: {lesson_id_lower}_{lesson_slug}",
        f'title: "{lesson_title}"',
        f'sidebar_label: "{lesson_title}"',
        f"sidebar_position: {sidebar_pos}",
        f"level: {level}",
        f'lesson_id: "{lesson_id}"',
        f'lesson_title: "{lesson_title}"',
        f"section_count: {len(sections_data)}",
        "sections:"
    ]
    for s in sections_data:
        yaml_lines.append(f"  - id: {s['id']}")
        yaml_lines.append(f"    title: \"{s['title']}\"")
        yaml_lines.append(f"    file: \"{s['file']}\"")
    yaml_lines.extend([
        f'language_version: "{language_version}"',
        f'course_language: "{course_language}"',
        "status: draft",
        f'created_at: "{current_date}"',
        "---\n"
    ])
    
    # Build body
    if course_language == "vi":
        body_lines = [
            f"# {lesson_title}\n",
            "## Giới thiệu bài học\n",
            "{/* HERMES:FILL lesson_introduction */}\n",
            ":::info Mục tiêu bài học\n",
            "Sau bài học này, bạn sẽ có thể:\n",
            "- [ ] {/* HERMES:FILL learning_objectives */}\n",
            ":::\n",
            "**Tiên quyết:**\n",
            "- {/* HERMES:FILL prerequisites */}\n",
            "\n**Thời gian ước tính:** {/* HERMES:FILL time_estimate */}\n",
            "---\n"
        ]
    else:
        body_lines = [
            f"# {lesson_title}\n",
            "## Lesson Introduction\n",
            "{/* HERMES:FILL lesson_introduction */}\n",
            ":::info Learning Objectives\n",
            "After this lesson, you will be able to:\n",
            "- [ ] {/* HERMES:FILL learning_objectives */}\n",
            ":::\n",
            "**Prerequisites:**\n",
            "- {/* HERMES:FILL prerequisites */}\n",
            "\n**Estimated Time:** {/* HERMES:FILL time_estimate */}\n",
            "---\n"
        ]
    
    for s in sections_data:
        body_lines.append(f"{{/* TRANSITION_BEFORE_{s['id']} */}}\n")
        demoted_body = demote_headings(s['body'])
        body_lines.append(demoted_body)
        body_lines.append(f"\n{{/* TRANSITION_AFTER_{s['id']} */}}\n")
        body_lines.append("---\n")
        
    if course_language == "vi":
        body_lines.extend([
            "## Tóm tắt bài học\n",
            "{/* HERMES:FILL lesson_recap */}\n",
            "## Bài tập tổng hợp\n",
            "{/* HERMES:FILL comprehensive_exercises */}\n",
            "## Trắc nghiệm\n",
            "{/* HERMES:FILL quiz_5_questions */}\n"
        ])
    else:
        body_lines.extend([
            "## Lesson Recap\n",
            "{/* HERMES:FILL lesson_recap */}\n",
            "## Comprehensive Exercises\n",
            "{/* HERMES:FILL comprehensive_exercises */}\n",
            "## Quiz\n",
            "{/* HERMES:FILL quiz_5_questions */}\n"
        ])
    
    lesson_content = "\n".join(yaml_lines) + "\n".join(body_lines)
    
    lesson_file_name = f"{lesson_id}_{lesson_slug}.mdx"
    lesson_file_path = os.path.join(target_path, f"output/lessons/{level}/{lesson_file_name}")
    
    with open(lesson_file_path, "w", encoding="utf-8") as f:
        f.write(lesson_content)
        
    print(f"\nLesson merged successfully to {lesson_file_path}")
    
    # Update changelog
    changelog_path = os.path.join(target_path, "output/changelog.md")
    if os.path.exists(changelog_path):
        with open(changelog_path, "a", encoding="utf-8") as f:
            f.write(f"\n## [{datetime.now().strftime('%Y-%m-%d %H:%M:%S +07:00')}]\n\n")
            f.write("### Merged\n\n")
            f.write(f"- `output/lessons/{level}/{lesson_file_name}` — {len(sections_data)} sections merged (automated via CLI).\n")
        print("Changelog updated")
        
    # Auto update state.md if possible
    update_state(target_path, "last_updated_at", datetime.now().strftime("%Y-%m-%d %H:%M:%S"))

def resolve_sections_dir(target_path, level):
    path1 = os.path.join(target_path, "output", "sections", level)
    if os.path.exists(path1):
        return path1
    path2 = os.path.join(target_path, "sections", level)
    if os.path.exists(path2):
        return path2
    path3 = os.path.join(target_path, level)
    if os.path.exists(path3):
        return path3
    return path1

def resolve_config_file(target_path, filename):
    path1 = os.path.join(target_path, filename)
    if os.path.exists(path1):
        return path1
    path2 = os.path.join(target_path, "output", filename)
    if os.path.exists(path2):
        return path2
    return path1

def parse_architecture(arch_path):
    lessons = {}
    sections = {}
    lesson_levels = {}
    if not os.path.exists(arch_path):
        return lessons, sections, lesson_levels
    with open(arch_path, "r", encoding="utf-8") as f:
        content = f.read()
    current_lesson_id = None
    current_level = None
    for line in content.split("\n"):
        line = line.strip()
        level_match = re.match(r'^##\s*(Level\s*:\s*)?(begin|advance|master)\b', line, re.IGNORECASE)
        if level_match:
            current_level = level_match.group(2).lower()
            continue
        lesson_match = re.match(r'^###\s*(L\d{2}):\s*(.*)$', line)
        if lesson_match:
            current_lesson_id = lesson_match.group(1).upper()
            lessons[current_lesson_id] = lesson_match.group(2).strip()
            if current_level:
                lesson_levels[current_lesson_id] = current_level
            continue
        if current_lesson_id:
            sec_match = re.match(r'^-\s*(S\d{2}):\s*(.*)$', line)
            if sec_match:
                sec_id = sec_match.group(1).upper()
                sections[(current_lesson_id, sec_id)] = sec_match.group(2).strip()
    return lessons, sections, lesson_levels

def check_mdx_safety(content):
    lines = content.splitlines()
    cleaned_lines = []
    
    in_yaml = False
    in_code_block = False
    in_mdx_comment = False
    
    for line_num, line in enumerate(lines, 1):
        stripped = line.strip()
        
        # 1. YAML frontmatter
        if line_num == 1 and stripped == "---":
            in_yaml = True
            cleaned_lines.append(" " * len(line))
            continue
        elif in_yaml:
            if stripped == "---":
                in_yaml = False
            cleaned_lines.append(" " * len(line))
            continue
            
        # 2. Fenced code block
        if stripped.startswith("```"):
            in_code_block = not in_code_block
            cleaned_lines.append(" " * len(line))
            continue
        elif in_code_block:
            cleaned_lines.append(" " * len(line))
            continue
            
        # 3. MDX comment
        if in_mdx_comment:
            if "*/}" in line:
                in_mdx_comment = False
                idx = line.find("*/}")
                line = " " * (idx+3) + line[idx+3:]
            else:
                cleaned_lines.append(" " * len(line))
                continue
        elif "{/*" in line:
            if "*/}" in line:
                pass
            else:
                in_mdx_comment = True
                idx = line.find("{/*")
                line = line[:idx] + " " * (len(line) - idx)
                
        # 4. Blank out inline code
        def blank_inline(match):
            return "`" + " " * (len(match.group(0)) - 2) + "`"
        line_clean = re.sub(r'`[^`\n]*`', blank_inline, line)
        
        # 5. Blank out single-line MDX comments
        line_clean = re.sub(r'\{\/\*.*?\*\/\}', lambda m: " " * len(m.group(0)), line_clean)
        
        cleaned_lines.append(line_clean)
        
    errors = []
    for line_num, line_clean in enumerate(cleaned_lines, 1):
        if re.match(r'^\s*>', line_clean):
            continue
            
        # Check for unescaped '<'
        for match in re.finditer(r'(?<!\\)<', line_clean):
            idx = match.start()
            suffix = line_clean[idx:]
            is_allowed = False
            for tag in ['<details>', '</details>', '<summary>', '</summary>', '<br />', '<br/>']:
                if suffix.lower().startswith(tag):
                    is_allowed = True
                    break
            if not is_allowed:
                context = line_clean[max(0, idx-10):min(len(line_clean), idx+15)].strip()
                errors.append(f"MDX safety error at line {line_num}: Unescaped '<' found in: '{context}'. Wrap in backticks or escape as '\\<'.")
                
        # Check for unescaped '>'
        for match in re.finditer(r'(?<!\\)>', line_clean):
            idx = match.start()
            prefix = line_clean[:idx+1]
            is_allowed = False
            for tag in ['<details>', '</details>', '<summary>', '</summary>', '<br />', '<br/>']:
                if prefix.lower().endswith(tag):
                    is_allowed = True
                    break
            if not is_allowed:
                context = line_clean[max(0, idx-15):min(len(line_clean), idx+10)].strip()
                errors.append(f"MDX safety error at line {line_num}: Unescaped '>' found in: '{context}'. Wrap in backticks or escape as '\\>'.")
                
        # Check for unescaped '{'
        for match in re.finditer(r'(?<!\\)\{', line_clean):
            idx = match.start()
            context = line_clean[max(0, idx-10):min(len(line_clean), idx+15)].strip()
            errors.append(f"MDX safety error at line {line_num}: Unescaped '{{' found in: '{context}'. Wrap in backticks, use JSX expression '{{\"{{\"}}', or escape as '\\{{'.")
            
        # Check for unescaped '}'
        for match in re.finditer(r'(?<!\\)\}', line_clean):
            idx = match.start()
            context = line_clean[max(0, idx-10):min(len(line_clean), idx+15)].strip()
            errors.append(f"MDX safety error at line {line_num}: Unescaped '}}' found in: '{context}'. Wrap in backticks, use JSX expression '{{\"}}\"}}', or escape as '\\}}'.")
            
    return errors

def run_docusaurus_build_check(target_path):
    print("\nRunning Docusaurus compilation check...")
    sample_path = os.path.join(target_path, "sample")
    
    # 1. Khởi tạo project Docusaurus nếu chưa có
    if not os.path.exists(sample_path):
        print("[INFO] Initializing sample Docusaurus project...")
        try:
            # Dùng capture_output=True và text=True để handle lỗi an toàn
            subprocess.run(
                ["npx", "-y", "create-docusaurus@latest", "sample", "classic", "--package-manager", "npm", "--javascript"],
                cwd=target_path,
                check=True,
                capture_output=True,
                text=True
            )
        except subprocess.CalledProcessError as e:
            # Thu thập stderr dễ dàng và an toàn hơn
            print(f"[FAIL] Failed to initialize sample Docusaurus:\n{e.stderr.strip() if e.stderr else 'Unknown Error'}")
            return False

    # 2. Cấu hình cảnh báo broken links
    config_path = os.path.join(sample_path, "docusaurus.config.js")
    if os.path.exists(config_path):
        try:
            with open(config_path, "r", encoding="utf-8") as f:
                cfg = f.read()
            
            cfg = re.sub(r"onBrokenLinks:\s*['\"](throw|warn|ignore|error)['\"]", "onBrokenLinks: 'warn'", cfg)
            if "onBrokenMarkdownLinks" not in cfg:
                cfg = re.sub(r"(onBrokenLinks:\s*['\"]warn['\"],?)", r"\1\n  onBrokenMarkdownLinks: 'warn',", cfg)
            else:
                cfg = re.sub(r"onBrokenMarkdownLinks:\s*['\"](throw|warn|ignore|error)['\"]", "onBrokenMarkdownLinks: 'warn'", cfg)
            
            with open(config_path, "w", encoding="utf-8") as f:
                f.write(cfg)
        except Exception as e:
            print(f"[WARN] Failed to configure sample/docusaurus.config.js: {e}")

    # 3. Tối ưu: Dọn dẹp nhanh thư mục docs mặc định
    docs_dir = os.path.join(sample_path, "docs")
    shutil.rmtree(docs_dir, ignore_errors=True)
    os.makedirs(docs_dir, exist_ok=True)

    # 4. Tối ưu: Copy sections vào Docusaurus (thay thế khối code dài dòng cũ)
    setup_failed = False
    for lvl in ["begin", "advance", "master"]:
        src_dir = os.path.abspath(os.path.join(target_path, "output", "sections", lvl))
        dst_dir = os.path.join(sample_path, "docs", lvl)
        
        if os.path.exists(src_dir):
            try:
                # Dọn sạch đích bằng 1 dòng trước khi copy đè
                shutil.rmtree(dst_dir, ignore_errors=True)
                shutil.copytree(src_dir, dst_dir)
            except Exception as ce:
                print(f"[FAIL] Failed to copy level '{lvl}' to Docusaurus docs: {ce}")
                setup_failed = True

    if setup_failed:
        print("\nVerification FAILED! Docusaurus environment could not be set up.")
        return False

    # 5. Build Docusaurus
    print("Compiling MDX files...")
    try:
        res = subprocess.run(
            ["npm", "run", "build"],
            cwd=sample_path,
            capture_output=True,
            text=True
        )
        if res.returncode == 0:
            print("[OK] Docusaurus compilation check passed.")
            return True
        else:
            print("[FAIL] Docusaurus compilation check failed!")
            print("\n--- Compiler Build Output ---")
            print(res.stdout)
            print(res.stderr)
            print("-----------------------------\n")
            return False
    except Exception as e:
        print(f"[FAIL] Failed to execute npm run build: {e}")
        return False

def cmd_verify(target_path, level_arg, build=False):
    state_path = resolve_config_file(target_path, "state.md")
    course_language = "en"
    if os.path.exists(state_path):
        course_language = read_state(os.path.dirname(state_path), "course_language") or "en"
    levels = ["begin", "advance", "master"] if level_arg == "all" else [level_arg]
    overall_passed = True
    for lvl in levels:
        sections_dir = resolve_sections_dir(target_path, lvl)
        if not os.path.exists(sections_dir):
            print(f"Skipping level '{lvl}': directory {sections_dir} does not exist.")
            continue
        print(f"Verifying sections for level: {lvl}")
        files = [f for f in os.listdir(sections_dir) if f.endswith(".mdx")]
        files.sort()
        for f in files:
            file_path = os.path.join(sections_dir, f)
            with open(file_path, "r", encoding="utf-8") as file:
                content = file.read()
            file_errors = []
            
            # Detect language of the file (fallback to course_language)
            file_lang = course_language
            if "## Giới thiệu" in content or "## Khái niệm cốt lõi" in content or "## Ví dụ minh họa" in content:
                file_lang = "vi"

            if file_lang == "vi":
                file_expected_headings = [
                    "Giới thiệu",
                    "Khái niệm cốt lõi",
                    "Ví dụ minh họa",
                    "Lỗi thường gặp",
                    "Thực hành tốt nhất",
                    "Bài tập nhỏ",
                    "Tóm tắt",
                    "Tài liệu tham khảo"
                ]
            else:
                file_expected_headings = [
                    "Introduction",
                    "Main Concepts",
                    "Code Examples",
                    "Common Mistakes",
                    "Best Practices",
                    "Mini Exercise",
                    "Summary",
                    "References"
                ]
            if not content.startswith("---"):
                file_errors.append("Missing frontmatter metadata block at the start of the file.")
                meta = {}
                body = content
            else:
                try:
                    meta, body = parse_frontmatter(content)
                    required_keys = [
                        "id", "title", "sidebar_label", "sidebar_position", 
                        "level", "lesson_id", "lesson_title", "section_id", 
                        "section_title", "language_version", "review_score", "status"
                    ]
                    for rk in required_keys:
                        if rk not in meta or str(meta[rk]).strip() == "":
                            file_errors.append(f"Missing or empty metadata key: '{rk}'.")
                    if "sidebar_position" in meta:
                        try:
                            int(meta["sidebar_position"])
                        except ValueError:
                            file_errors.append(f"Metadata 'sidebar_position' must be an integer, got '{meta['sidebar_position']}'.")
                    if "review_score" in meta:
                        try:
                            float(meta["review_score"])
                        except ValueError:
                            file_errors.append(f"Metadata 'review_score' must be a float, got '{meta['review_score']}'.")
                    if "level" in meta and meta["level"] not in ["begin", "advance", "master"]:
                        file_errors.append(f"Metadata 'level' must be 'begin', 'advance', or 'master', got '{meta['level']}'.")
                    if "status" in meta and meta["status"] not in ["draft", "reviewed", "approved"]:
                        file_errors.append(f"Metadata 'status' must be 'draft', 'reviewed', or 'approved', got '{meta['status']}'.")
                    if "lesson_id" in meta and not re.match(r'^L\d{2}$', meta["lesson_id"]):
                        file_errors.append(f"Metadata 'lesson_id' must match format Lxx, got '{meta['lesson_id']}'.")
                    if "section_id" in meta and not re.match(r'^S\d{2}$', meta["section_id"]):
                        file_errors.append(f"Metadata 'section_id' must match format Sxx, got '{meta['section_id']}'.")
                except Exception as e:
                    file_errors.append(f"Failed to parse frontmatter: {str(e)}")
                    meta = {}
                    body = content
            
            # Check MDX safety errors
            safety_errors = check_mdx_safety(content)
            file_errors.extend(safety_errors)

            lines = body.split("\n")
            headings = []
            in_code_block = False
            for line in lines:
                stripped = line.strip()
                if stripped.startswith("```"):
                    in_code_block = not in_code_block
                    continue
                if not in_code_block and stripped.startswith("#"):
                    headings.append(stripped)
            l1_headings = [h for h in headings if h.startswith("# ") and not h.startswith("##")]
            if len(l1_headings) == 0:
                file_errors.append("Missing Level-1 heading (# Section Title).")
            elif len(l1_headings) > 1:
                file_errors.append(f"Multiple Level-1 headings found: {l1_headings}.")
            else:
                if "section_title" in meta:
                    l1_title = re.sub(r'[^a-zA-Z0-9\s]', '', l1_headings[0][2:].strip().lower())
                    l1_title = re.sub(r'^l\d{2}\s*s\d{2}\s*[\s:]*', '', l1_title)
                    meta_title = re.sub(r'[^a-zA-Z0-9\s]', '', str(meta["section_title"]).strip().lower().strip('"\''))
                    if meta_title not in l1_title and l1_title not in meta_title:
                        file_errors.append(f"Level-1 heading '{l1_headings[0]}' does not match 'section_title' '{meta['section_title']}'.")
            l2_headings = [h[3:].strip() for h in headings if h.startswith("## ") and not h.startswith("###")]
            for h2 in l2_headings:
                if h2 not in file_expected_headings and h2 not in ["Prerequisites", "Tiên quyết"]:
                    file_errors.append(f"Forbidden custom level-2 heading found: '## {h2}'. Custom subheadings must use level-3 (###) or level-4 (####).")
            missing_headings = [eh for eh in file_expected_headings if eh not in l2_headings]
            if missing_headings:
                file_errors.append(f"Missing standard level-2 headings: {missing_headings}.")
            else:
                curr_idx = -1
                out_of_order = False
                for h2 in l2_headings:
                    if h2 in file_expected_headings:
                        idx = file_expected_headings.index(h2)
                        if idx < curr_idx:
                            out_of_order = True
                        curr_idx = idx
                if out_of_order:
                    file_errors.append("Standard level-2 headings are not in the correct order.")
            if file_errors:
                overall_passed = False
                print(f"[FAIL] {f}:")
                for err in file_errors:
                    print(f"  - {err}")
            else:
                print(f"[OK] {f}")
    if build:
        build_passed = run_docusaurus_build_check(target_path)
        if not build_passed:
            overall_passed = False

    if overall_passed:
        print("\nVerification PASSED! All checked files are fully compliant.")
        return True
    else:
        print("\nVerification FAILED! Some files do not meet the requirements.")
        return False

def cmd_status(target_path, level_arg=None, json_mode=False):
    # Support both state.json and state.md
    state_path_json = os.path.join(target_path, "state.json")
    state_path_md = os.path.join(target_path, "state.md")
    if not os.path.exists(state_path_json) and not os.path.exists(state_path_md):
        print(f"Error: State file not found in {target_path}", file=sys.stderr)
        sys.exit(1)
        
    tech = read_state(target_path, "technology") or ""
    tech_ver = read_state(target_path, "technology_version") or ""
    course_name = read_state(target_path, "course_name") or ""
    lang = read_state(target_path, "course_language") or "en"
    active_lvl = read_state(target_path, "active_level") or ""
    active_les = read_state(target_path, "active_lesson_id") or ""
    active_sec = read_state(target_path, "active_section_id") or ""
    locked_sec = read_state(target_path, "locked_section") or ""
    
    if not json_mode:
        print("Workspace Status:")
        print(f"- Technology: {tech} ({tech_ver})")
        print(f"- Course Name: {course_name}")
        print(f"- Language: {lang}")
        print(f"- Active Level: {active_lvl}")
        print(f"- Active Lesson: {active_les}")
        print(f"- Active Section: {active_sec}")
        print(f"- Locked Section: {locked_sec if locked_sec else 'None'}")
        print()
        
    arch_path = resolve_config_file(target_path, "architecture.md")
    if not os.path.exists(arch_path):
        print(f"Error: architecture.md not found at {arch_path}", file=sys.stderr)
        sys.exit(1)
        
    arch_lessons, arch_sections, lesson_levels = parse_architecture(arch_path)
    
    if level_arg and level_arg != "all":
        levels_to_check = [level_arg]
    elif active_lvl:
        levels_to_check = [active_lvl]
    else:
        levels_to_check = ["begin", "advance", "master"]
        
    json_output = {
        "workspace": {
            "technology": tech,
            "technology_version": tech_ver,
            "course_name": course_name,
            "course_language": lang,
            "active_level": active_lvl,
            "active_lesson_id": active_les,
            "active_section_id": active_sec,
            "locked_section": locked_sec
        },
        "levels": {}
    }
    
    for lvl in levels_to_check:
        if not json_mode:
            print(f"Level: {lvl}")
            print("-" * 80)
            print(f"{'Lesson/Section ID':<20} | {'Title':<40} | {'Status':<10} | {'Score':<5}")
            print("-" * 80)
            
        level_lessons = [les_id for les_id, les_lvl in lesson_levels.items() if les_lvl == lvl]
        if not level_lessons:
            if not lesson_levels:
                level_lessons = sorted(list(arch_lessons.keys()))
            else:
                if not json_mode:
                    print(f"No lessons defined for level '{lvl}' in architecture.md")
                    print("-" * 80)
                    print()
                json_output["levels"][lvl] = {
                    "summary": {
                        "total": 0,
                        "approved": 0,
                        "draft": 0,
                        "needs_revision": 0,
                        "pending": 0,
                        "completion_percentage": 0.0
                    },
                    "sections": []
                }
                continue
                
        sections_dir = os.path.join(target_path, f"output/sections/{lvl}")
        existing_files = []
        if os.path.exists(sections_dir):
            existing_files = [f for f in os.listdir(sections_dir) if f.endswith(".mdx")]
            
        total_sec = 0
        approved_sec = 0
        draft_sec = 0
        revision_sec = 0
        pending_sec = 0
        level_sections_json = []
        
        for les_id in sorted(level_lessons):
            les_title = arch_lessons.get(les_id, "Unknown Lesson")
            if not json_mode:
                print(f"{les_id}: {les_title}")
                
            les_sections = [sec_id for (l_id, sec_id) in arch_sections.keys() if l_id == les_id]
            for sec_id in sorted(les_sections):
                total_sec += 1
                sec_title = arch_sections.get((les_id, sec_id), "Unknown Section")
                
                matched_file = None
                for f in existing_files:
                    if f.startswith(f"{les_id}_{sec_id}_"):
                        matched_file = f
                        break
                        
                status = "Pending"
                score = "-"
                
                if matched_file:
                    file_path = os.path.join(sections_dir, matched_file)
                    try:
                        with open(file_path, "r", encoding="utf-8") as f:
                            content = f.read()
                        meta, _ = parse_frontmatter(content)
                        status_val = meta.get("status", "draft")
                        score_val = meta.get("review_score", "0.0")
                        
                        if status_val == "approved":
                            status = "Approved"
                            approved_sec += 1
                        elif status_val == "needs-revision":
                            status = "Revision"
                            revision_sec += 1
                        else:
                            status = "Draft"
                            draft_sec += 1
                        score = str(score_val)
                    except Exception:
                        status = "Error"
                        draft_sec += 1
                else:
                    pending_sec += 1
                    
                if not json_mode:
                    print(f"  {sec_id:<18} | {sec_title[:40]:<40} | {status:<10} | {score:<5}")
                
                level_sections_json.append({
                    "lesson_id": les_id,
                    "section_id": sec_id,
                    "title": sec_title,
                    "status": status,
                    "score": score,
                    "file": matched_file or ""
                })
        
        pct = 0.0
        if total_sec > 0:
            pct = (approved_sec / total_sec) * 100
            
        if not json_mode:
            print("-" * 80)
            print(f"Summary for level '{lvl}':")
            print(f"- Total Sections: {total_sec}")
            print(f"- Approved: {approved_sec}")
            print(f"- Draft: {draft_sec}")
            print(f"- Needs Revision: {revision_sec}")
            print(f"- Pending: {pending_sec}")
            if total_sec > 0:
                print(f"- Completion: {pct:.1f}%")
            print()
            
        json_output["levels"][lvl] = {
            "summary": {
                "total": total_sec,
                "approved": approved_sec,
                "draft": draft_sec,
                "needs_revision": revision_sec,
                "pending": pending_sec,
                "completion_percentage": round(pct, 1)
            },
            "sections": level_sections_json
        }
        
    if json_mode:
        print(json.dumps(json_output, indent=2))

def cmd_evaluate(target_path, level, filename):
    target_path = os.path.abspath(target_path)
    sections_dir = os.path.join(target_path, "output", "sections", level)
    file_path = os.path.join(sections_dir, filename)
    
    report = {
        "file": filename,
        "level": level,
        "passed": False,
        "errors": [],
        "metadata": {}
    }
    
    if not os.path.exists(file_path):
        report["errors"].append(f"File not found: {file_path}")
        print(json.dumps(report, indent=2))
        return False
        
    try:
        with open(file_path, "r", encoding="utf-8") as file:
            content = file.read()
    except Exception as e:
        report["errors"].append(f"Failed to read file: {e}")
        print(json.dumps(report, indent=2))
        return False
        
    file_errors = []
    
    # 1. Frontmatter
    meta = {}
    body = content
    if not content.startswith("---"):
        file_errors.append("Missing frontmatter metadata block at the start of the file.")
    else:
        try:
            meta, body = parse_frontmatter(content)
            report["metadata"] = meta
            required_keys = [
                "id", "title", "sidebar_label", "sidebar_position", 
                "level", "lesson_id", "lesson_title", "section_id", 
                "section_title", "language_version", "review_score", "status"
            ]
            for rk in required_keys:
                if rk not in meta or str(meta[rk]).strip() == "":
                    file_errors.append(f"Missing or empty metadata key: '{rk}'.")
            if "sidebar_position" in meta:
                try:
                    int(meta["sidebar_position"])
                except ValueError:
                    file_errors.append(f"Metadata 'sidebar_position' must be an integer, got '{meta['sidebar_position']}'.")
            if "review_score" in meta:
                try:
                    float(meta["review_score"])
                except ValueError:
                    file_errors.append(f"Metadata 'review_score' must be a float, got '{meta['review_score']}'.")
            if "level" in meta and meta["level"] not in ["begin", "advance", "master"]:
                file_errors.append(f"Metadata 'level' must be 'begin', 'advance', or 'master', got '{meta['level']}'.")
            if "status" in meta and meta["status"] not in ["draft", "reviewed", "approved"]:
                file_errors.append(f"Metadata 'status' must be 'draft', 'reviewed', or 'approved', got '{meta['status']}'.")
            if "lesson_id" in meta and not re.match(r'^L\d{2}$', meta["lesson_id"]):
                file_errors.append(f"Metadata 'lesson_id' must match format Lxx, got '{meta['lesson_id']}'.")
            if "section_id" in meta and not re.match(r'^S\d{2}$', meta["section_id"]):
                file_errors.append(f"Metadata 'section_id' must match format Sxx, got '{meta['section_id']}'.")
        except Exception as e:
            file_errors.append(f"Failed to parse frontmatter: {str(e)}")
            
    # 2. MDX Safety
    safety_errors = check_mdx_safety(content)
    file_errors.extend(safety_errors)
    
    # 3. Headings Structure
    course_language = "en"
    state_path_json = os.path.join(target_path, "state.json")
    state_path_md = os.path.join(target_path, "state.md")
    if os.path.exists(state_path_json) or os.path.exists(state_path_md):
        course_language = read_state(target_path, "course_language") or "en"
        
    file_lang = course_language
    if "## Giới thiệu" in content or "## Khái niệm cốt lõi" in content or "## Ví dụ minh họa" in content:
        file_lang = "vi"
        
    if file_lang == "vi":
        file_expected_headings = [
            "Giới thiệu",
            "Khái niệm cốt lõi",
            "Ví dụ minh họa",
            "Lỗi thường gặp",
            "Thực hành tốt nhất",
            "Bài tập nhỏ",
            "Tóm tắt",
            "Tài liệu tham khảo"
        ]
    else:
        file_expected_headings = [
            "Introduction",
            "Main Concepts",
            "Code Examples",
            "Common Mistakes",
            "Best Practices",
            "Mini Exercise",
            "Summary",
            "References"
        ]
        
    lines = body.split("\n")
    headings = []
    in_code_block = False
    for line in lines:
        stripped = line.strip()
        if stripped.startswith("```"):
            in_code_block = not in_code_block
            continue
        if not in_code_block and stripped.startswith("#"):
            headings.append(stripped)
            
    l1_headings = [h for h in headings if h.startswith("# ") and not h.startswith("##")]
    if len(l1_headings) == 0:
        file_errors.append("Missing Level-1 heading (# Section Title).")
    elif len(l1_headings) > 1:
        file_errors.append(f"Multiple Level-1 headings found: {l1_headings}.")
    else:
        if "section_title" in meta:
            l1_title = re.sub(r'[^a-zA-Z0-9\s]', '', l1_headings[0][2:].strip().lower())
            l1_title = re.sub(r'^l\d{2}\s*s\d{2}\s*[\s:]*', '', l1_title)
            meta_title = re.sub(r'[^a-zA-Z0-9\s]', '', str(meta["section_title"]).strip().lower().strip('"\''))
            if meta_title not in l1_title and l1_title not in meta_title:
                file_errors.append(f"Level-1 heading '{l1_headings[0]}' does not match 'section_title' '{meta['section_title']}'.")
                
    l2_headings = [h[3:].strip() for h in headings if h.startswith("## ") and not h.startswith("###")]
    for h2 in l2_headings:
        if h2 not in file_expected_headings and h2 not in ["Prerequisites", "Tiên quyết"]:
            file_errors.append(f"Forbidden custom level-2 heading found: '## {h2}'. Custom subheadings must use level-3 (###) or level-4 (####).")
            
    missing_headings = [eh for eh in file_expected_headings if eh not in l2_headings]
    if missing_headings:
        file_errors.append(f"Missing standard level-2 headings: {missing_headings}.")
    else:
        curr_idx = -1
        out_of_order = False
        for h2 in l2_headings:
            if h2 in file_expected_headings:
                idx = file_expected_headings.index(h2)
                if idx < curr_idx:
                    out_of_order = True
                curr_idx = idx
        if out_of_order:
            file_errors.append("Standard level-2 headings are not in the correct order.")
            
    report["errors"] = file_errors
    report["passed"] = (len(file_errors) == 0)
    
    print(json.dumps(report, indent=2))
    return report["passed"]


def cmd_reorder(target_path, level_arg, mode):
    arch_path = resolve_config_file(target_path, "architecture.md")
    arch_lessons, arch_sections, _ = parse_architecture(arch_path)
    levels = ["begin", "advance", "master"] if level_arg == "all" else [level_arg]
    for lvl in levels:
        sections_dir = resolve_sections_dir(target_path, lvl)
        if not os.path.exists(sections_dir):
            print(f"Skipping level '{lvl}': directory {sections_dir} does not exist.")
            continue
        print(f"Reordering sections for level: {lvl} (mode: {mode})")
        files = [f for f in os.listdir(sections_dir) if f.endswith(".mdx")]
        file_sort_keys = []
        for f in files:
            match = re.match(r'^(L\d{2})_(S\d{2})', f)
            if match:
                file_sort_keys.append((match.group(1).upper(), match.group(2).upper(), f))
            else:
                file_sort_keys.append(("ZZZ", "ZZZ", f))
        file_sort_keys.sort()
        lesson_counters = {}
        for idx, (lesson_id, sec_id, f) in enumerate(file_sort_keys):
            file_path = os.path.join(sections_dir, f)
            with open(file_path, "r", encoding="utf-8") as file:
                content = file.read()
            has_frontmatter = content.startswith("---")
            meta = {}
            body = content
            if has_frontmatter:
                meta, body = parse_frontmatter(content)
            if not has_frontmatter or not meta:
                les_id = lesson_id if lesson_id != "ZZZ" else "L01"
                s_id = sec_id if sec_id != "ZZZ" else "S01"
                les_title = arch_lessons.get(les_id, "Introduction")
                s_title = arch_sections.get((les_id, s_id), "")
                if not s_title:
                    l1_match = re.search(r'^#\s+(.*)$', body, re.MULTILINE)
                    if l1_match:
                        s_title = l1_match.group(1).strip()
                        s_title = re.sub(r'^L\d{2}\s*S\d{2}[:\s]*', '', s_title)
                    else:
                        s_title = "Section Title"
                slug_str = slugify(s_title)
                meta = {
                    "id": f"{les_id.lower()}_{s_id.lower()}_{slug_str}",
                    "title": s_title,
                    "sidebar_label": s_title,
                    "sidebar_position": 1,
                    "level": lvl,
                    "lesson_id": les_id,
                    "lesson_title": les_title,
                    "section_id": s_id,
                    "section_title": s_title,
                    "language_version": "1.0.0",
                    "review_score": "0.0",
                    "status": "draft"
                }
            if mode == "flat":
                sidebar_pos = idx + 1
            else:
                les_id = meta.get("lesson_id", "L01")
                lesson_counters[les_id] = lesson_counters.get(les_id, 0) + 1
                sidebar_pos = lesson_counters[les_id]
            meta["sidebar_position"] = sidebar_pos
            yaml_lines = ["---"]
            ordered_keys = [
                "id", "title", "sidebar_label", "sidebar_position", 
                "level", "lesson_id", "lesson_title", "section_id", 
                "section_title", "language_version", "review_score", "status"
            ]
            for k in ordered_keys:
                if k in meta:
                    val = meta[k]
                    if k in ["title", "sidebar_label", "lesson_id", "lesson_title", "section_id", "section_title", "language_version"]:
                        val = str(val).strip().strip('"\'')
                        yaml_lines.append(f'{k}: "{val}"')
                    else:
                        yaml_lines.append(f'{k}: {val}')
            for k, val in meta.items():
                if k not in ordered_keys:
                    yaml_lines.append(f'{k}: {val}')
            yaml_lines.append("---")
            new_content = "\n".join(yaml_lines) + "\n" + body.strip() + "\n"
            with open(file_path, "w", encoding="utf-8") as file:
                file.write(new_content)
            print(f"  Updated {f}: sidebar_position={sidebar_pos}")
    print("Reordering and metadata fix completed.")

if __name__ == "__main__":
    main()
